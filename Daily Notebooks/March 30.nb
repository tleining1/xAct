  RowBox[{"{", 
   RowBox[{"expr__", ":>", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "list", ",", "casesEp", ",", "Ee", ",", "termIndex", ",", "contEp", 
