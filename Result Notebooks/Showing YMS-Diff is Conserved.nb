Cell["\<\
-(k*epsilong[-b, c]*CD[b][CD[a][\[Phi][]]]*CD[-c][CD[-a][\[Phi][]]]) - 
 k^2*CD[b][A[a]]*CD[-c][CD[-b][\[Phi][]]]*CD[c][CD[-a][\[Phi][]]] + 
 k^2*CD[b][A[a]]*CD[-c][CD[-a][\[Phi][]]]*CD[c][CD[-b][\[Phi][]]] - 
 2*k^2*CD[a][\[Phi][]]*CD[-b][CD[-a][A[-c]]]*CD[c][CD[b][\[Phi][]]] + 
 2*k^2*CD[a][\[Phi][]]*CD[-c][CD[-a][A[-b]]]*CD[c][CD[b][\[Phi][]]] + 
 3*k*epsilong[-c, d]*CD[c][CD[b][A[a]]]*CD[-d][CD[-a][A[-b]]] - 
 k*epsilong[-c, d]*CD[c][CD[b][A[a]]]*CD[-d][CD[-b][A[-a]]] - 
 k*epsilong[-b, c]*CD[b][CD[-a][A[a]]]*CD[-d][CD[-c][A[d]]] + 
 k*epsilong[-b, c]*CD[b][A[a]]*CD[-d][CD[-c][CD[-a][A[d]]]] + 
 k^2*CD[b][A[a]]*CD[c][CD[-b][A[-a]]]*CD[-d][CD[d][A[-c]]] - 
 k^2*CD[b][A[a]]*CD[-c][CD[-b][A[-a]]]*CD[-d][CD[d][A[c]]] - 
 k^2*CD[b][A[a]]*CD[-d][CD[-b][A[-c]]]*CD[d][CD[-a][A[c]]] + 
 k^2*CD[b][A[a]]*CD[-d][CD[-a][A[-c]]]*CD[d][CD[-b][A[c]]] - 
 k*epsilong[-b, -d]*CD[b][A[a]]*CD[d][CD[-c][CD[-a][A[c]]]] - 
 2*k^2*CD[b][A[a]]*CD[-c][CD[-b][A[-d]]]*CD[d][CD[c][A[-a]]] + 
 2*k^2*CD[b][A[a]]*CD[-d][CD[-b][A[-c]]]*CD[d][CD[c][A[-a]]]\
\>", "Output",
